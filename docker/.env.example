# HeurChain — Docker standalone configuration
# Copy this file to .env and adjust values for your environment.
# Run: docker compose -f docker-compose.standalone.yml up -d --build
#
# Requires Docker Compose v2 (docker compose plugin or docker-compose >= 2.x).

# Host-side port bindings.
# These control which ports are exposed on your host machine.
# Internal container ports are always 3010 (mcp) and 3012 (broker).
MCP_PORT=3010
HEURCHAIN_PORT=3012
NGINX_PORT=80

# Vault paths — where markdown files are stored on the host.
# On a fresh install, leave as defaults; Docker will create the directories.
OBSIDIAN_VAULT_PATH=./data/obsidian-vault
ORI_VAULT_PATH=./data/ori-vault

# Grafana credentials (used by the MCP server's Grafana tools).
# Only relevant if you run Grafana alongside this stack.
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Ollama URL for the HeurChain consolidation worker.
# Point at a local or remote Ollama instance.
# host.docker.internal resolves to the host machine from inside a container.
OLLAMA_URL=http://host.docker.internal:11434

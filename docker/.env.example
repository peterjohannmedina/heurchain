# Memory Stack — Docker standalone configuration
# Copy this file to .env and adjust values for your environment.

# Port assignments
MCP_PORT=3010
HEURCHAIN_PORT=3012
NGINX_PORT=80

# Vault paths — where markdown files are stored on the host.
# Both services share the obsidian vault.
# On a fresh install, leave as default and the directories will be created.
OBSIDIAN_VAULT_PATH=./data/obsidian-vault
ORI_VAULT_PATH=./data/ori-vault

# Grafana credentials (used by the MCP server's Grafana tools).
# Only relevant if you are running Grafana alongside this stack.
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Ollama URL for the HeurChain consolidation worker.
# Point at a local or remote Ollama instance.
# If Ollama runs on the host, host.docker.internal resolves correctly.
OLLAMA_URL=http://host.docker.internal:11434

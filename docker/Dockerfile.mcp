FROM node:22-slim

WORKDIR /app

COPY mcp-app/package.json ./
RUN npm install --omit=dev

COPY mcp-app/server.js ./

ENV NODE_ENV=production \
    MCP_PORT=3010 \
    REDIS_URL=redis://localhost:6379 \
    OBSIDIAN_VAULT_PATH=/opt/obsidian-vault \
    HEURCHAIN_URL=http://localhost:3012

EXPOSE 3010

HEALTHCHECK --interval=15s --timeout=5s --retries=3 --start-period=45s \
  CMD node -e "const h=require('http');h.get('http://localhost:3010/health',r=>{process.exit(r.statusCode===200?0:1)}).on('error',()=>process.exit(1))"

CMD ["node", "server.js"]

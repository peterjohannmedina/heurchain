global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: "mcp-server"
    static_configs:
      - targets: ["heurchain-mcp:{{ mcp_port }}"]
        labels:
          service: "heurchain-mcp"

  - job_name: "nginx"
    static_configs:
      - targets: ["nginx-gateway:80"]
        labels:
          service: "nginx-gateway"

  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

worker_processes 1;
master_process off;
events { worker_connections 512; }

http {
    resolver 127.0.0.11 valid=30s;

    server {
        listen 80;
        server_name _;

        location /health {
            proxy_pass http://obsidian-mcp:{{ mcp_port }}/health;
            proxy_set_header Host $host;
        }

        location /sse {
            proxy_pass http://obsidian-mcp:{{ mcp_port }}/sse;
            proxy_set_header Host $host;
            proxy_set_header Connection '';
            proxy_http_version 1.1;
            chunked_transfer_encoding off;
            proxy_buffering off;
            proxy_cache off;
            proxy_read_timeout 86400s;
        }

        location /messages {
            proxy_pass http://obsidian-mcp:{{ mcp_port }}/messages;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
        }

        location /api/ {
            proxy_pass http://obsidian-mcp:{{ mcp_port }}/api/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        location / {
            return 200 "Second-Brain MCP Gateway - OK\n";
            add_header Content-Type text/plain;
        }
    }
}
